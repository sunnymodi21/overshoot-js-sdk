{
  "name": "overshoot",
  "version": "2.0.0-alpha.6",
  "description": "Real-time vision AI SDK with sub-second latency. Process any live video stream source (camera, screen share, livekit ... etc) using state-of-the-art vision language models.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "prepublishOnly": "npm run build && npm run type-check && npm test"
  },
  "keywords": [
    "realtime",
    "vision",
    "ai",
    "video",
    "stream",
    "webrtc",
    "computer-vision",
    "machine-learning",
    "typescript",
    "ocr",
    "object-detection",
    "screen-capture",
    "livekit",
    "vlm",
    "multimodal",
    "video-analysis",
    "inference"
  ],
  "author": "Overshoot",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Overshoot-ai/overshoot-js-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Overshoot-ai/overshoot-js-sdk/issues"
  },
  "homepage": "https://overshoot.ai",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/ui": "^1.2.0",
    "eslint": "^8.56.0",
    "jsdom": "^27.0.1",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "hls.js": "^1.6.15",
    "livekit-client": "^2.9.0"
  },
  "packageManager": "pnpm@10.17.0+sha512.fce8a3dd29a4ed2ec566fb53efbb04d8c44a0f05bc6f24a73046910fb9c3ce7afa35a0980500668fa3573345bd644644fa98338fa168235c80f4aa17aa17fbef"
}
